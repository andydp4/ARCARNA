  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "NODE_ENV=development DEV_AUTH_BYPASS=1 tsx server/index.ts",
    "build": "vite build && npm run build:portal && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "build:portal": "node scripts/build-portal.mjs",
    "deploy:build": "npm run build",
    "deploy": "bash scripts/deploy-production.sh",
    "deploy:start": "pm2 start ecosystem.config.cjs",
    "deploy:restart": "pm2 delete midnight-epos 2>/dev/null || true; pm2 start ecosystem.config.cjs && pm2 save",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc",
    "lint": "eslint \"client/src/**/*.{ts,tsx}\"",
    "lint:strict": "eslint \"client/src/**/*.{ts,tsx}\" --max-warnings 0",
    "lint:a11y-new": "eslint client/src/components/OnboardingResumeBanner.tsx client/src/components/CommandPalette.tsx client/src/pages/onboarding-wizard.tsx --max-warnings 0",
    "db:push": "drizzle-kit push",
    "seed": "tsx scripts/seed.ts",
    "backfill": "tsx scripts/backfill-org.ts",
    "phase2d:seed": "tsx scripts/phase2d-seed.ts",
    "phase2d:test": "tsx scripts/phase2d-test.ts",
    "auth:link-clerk": "tsx scripts/link-clerk-auth-by-email.ts",
    "gate": "tsx scripts/release-gate.ts",
    "db:migrate": "bash scripts/apply-migrations-pm2.sh",
    "migration:sanity": "tsx scripts/migration-sanity-check.ts",
    "release:preflight": "npm run migration:sanity && npm run gate",
    "wave10:preflight": "bash scripts/wave10-preflight.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --project=e2e",
    "test:a11y": "playwright test --project=a11y",
    "dev:e2e": "NODE_ENV=development DEV_AUTH_BYPASS=1 tsx server/index.ts"
  },
