# ARCARNA EPOS — dedicated subdomain, served at site root.
# Target: https://arcarna.viger.cloud/   (app proxied from Node on 127.0.0.1:5000)
#
# Install:
#   sudo cp deploy/nginx-arcarna.viger.cloud.conf.example /etc/nginx/sites-available/arcarna.viger.cloud
#   sudo ln -s /etc/nginx/sites-available/arcarna.viger.cloud /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#   sudo certbot --nginx -d arcarna.viger.cloud      # provisions TLS + rewrites this to listen 443
#
# Prereq: DNS A/AAAA record  arcarna.viger.cloud -> <your VPS IP>

server {
    listen 80;
    listen [::]:80;
    server_name arcarna.viger.cloud;

    # App is served at root on this subdomain (VITE_BASE_PATH=/).
    location / {
        proxy_pass http://127.0.0.1:5000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 120s;
    }
}

# After `certbot --nginx -d arcarna.viger.cloud` runs, it adds the TLS (443) server
# block automatically and redirects 80 -> 443. Then add this header inside the 443
# block (HSTS — see docs/DEPLOY_HOSTINGER_VPS.md):
#   add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

# OPTIONAL — redirect the old path-based URL to the new subdomain (for bookmarks).
# Add inside the EXISTING viger.cloud server block (deploy/nginx-viger.cloud.conf.example):
#   location /arcarna/ { return 301 https://arcarna.viger.cloud$request_uri; }
#   location = /arcarna { return 301 https://arcarna.viger.cloud/; }
#   location /midnight/ { return 301 https://arcarna.viger.cloud/; }
