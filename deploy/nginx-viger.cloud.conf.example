# Example Nginx site for viger.cloud
# Cloudflare DNS/proxy/cache: see docs/ops/CLOUDFLARE.md
# - /           → Viger Cloud portal (static, served by Node from dist/portal)
# - /arcarna   → ARCARNA EPOS (Node on :5000)
# - Legacy: /midnight → 301 to /arcarna (app-level + optional edge redirect below)
# - /files, /backups → portal placeholder pages
#
# After Certbot: use the HTTPS server block below (or add HSTS to the block Certbot creates).

server {
    listen 80;
    server_name viger.cloud www.viger.cloud;

    client_max_body_size 25m;

    location /midnight/ {
        rewrite ^/midnight/(.*)$ /arcarna/$1 permanent;
    }

    location = /midnight {
        return 301 /arcarna/;
    }

    location / {
        proxy_pass http://127.0.0.1:5000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}

# HTTPS (after `certbot --nginx -d viger.cloud -d www.viger.cloud`)
