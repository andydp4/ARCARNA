# Example Nginx site for viger.cloud — the standalone "shop window" portal.
# Cloudflare DNS/proxy/cache: see docs/ops/CLOUDFLARE.md
#
# In the subdomain world the portal is DECOUPLED from the Arcarna Node app:
# - viger.cloud (this file) → serves the static portal directly (no Node).
# - arcarna.viger.cloud      → the Arcarna Node app (see deploy/nginx-arcarna.viger.cloud.conf.example).
#
# The portal is static files in the repo at /root/ARCARNA/portal/
# (index.html, files.html, backups.html, portal-assets/). No build/runtime needed.
#
# After Certbot: `sudo certbot --nginx -d viger.cloud -d www.viger.cloud`

server {
    listen 80;
    listen [::]:80;
    server_name viger.cloud www.viger.cloud;

    root /root/ARCARNA/portal;
    index index.html;

    # Send old app URLs to the new subdomain while preserving deep links + query strings.
    location = /arcarna { return 301 https://arcarna.viger.cloud/$is_args$args; }
    location = /midnight { return 301 https://arcarna.viger.cloud/$is_args$args; }
    location ~ ^/(?:arcarna|midnight)(?<legacy_path>/.*)$ {
        return 301 https://arcarna.viger.cloud$legacy_path$is_args$args;
    }

    # Root-level app bookmarks that used to be handled by Node when viger.cloud proxied it.
    location ~ ^/(?<epos_path>(?:pos|orders|inventory|products|insights|reports|analytics|locations|customers|loyalty|promotions|expenses|expense-reports|invoices|settings|tick-list|user-access|worker-logs|rules|scheduled-reports|purchase-drafts|sign-in|pending-approval|onboarding|onboarding/wizard|no-access|setup-wizard|setup-blocked))$ {
        return 301 https://arcarna.viger.cloud/$epos_path$is_args$args;
    }

    # Static portal. try_files lets /files → files.html, /backups → backups.html.
    location / {
        try_files $uri $uri/ $uri.html =404;
    }
}

# After `certbot --nginx -d viger.cloud -d www.viger.cloud` it adds the 443 block
# and the HTTP→HTTPS redirect. Add HSTS inside the 443 block:
#   add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
