# =============================================================================
# ARCARNA EPOS production — Node/PM2/Nginx (https://arcarna.viger.cloud) or Docker
# =============================================================================
# Copy:  cp .env.production.example .env
# Clerk: docs/AUTH_SETUP_CLERK.md
# PM2:  docs/DEPLOY_HOSTINGER_VPS.md
# =============================================================================

NODE_ENV=production
PORT=5000

# PostgreSQL (Neon or self-hosted) — rotate credentials if ever exposed in chat/logs
# Neon production: use pooled host (-pooler.neon.tech) from Neon dashboard
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.region.aws.neon.tech/DATABASE?sslmode=require

# Worker poll tuning (optional — lower = faster jobs, higher Neon CU usage)
# WORKER_DISPATCH_INTERVAL_MS=5000
# WORKER_PROCESS_INTERVAL_MS=2000
# WORKER_CONCURRENCY=1

# Session signing (32+ random characters; required even with Clerk)
SESSION_SECRET=CHANGE_ME_session_secret_at_least_32_characters

# Auth: clerk (production default) | replit (legacy rollback only)
AUTH_PROVIDER=clerk
CLERK_SECRET_KEY=sk_live_CHANGE_ME
CLERK_PUBLISHABLE_KEY=pk_live_CHANGE_ME

# Baked into frontend at npm run build (must match Clerk dashboard)
VITE_AUTH_PROVIDER=clerk
VITE_CLERK_PUBLISHABLE_KEY=pk_live_CHANGE_ME
# Public URL of the EPOS app — subdomain, served at site root
VITE_APP_URL=https://arcarna.viger.cloud
# Site root. "/" normalizes to "" (no path prefix). Must be present in the BUILD env.
VITE_BASE_PATH=/
APP_BASE_PATH=/

# Clerk Account Portal (DNS must point accounts.* to Clerk — see docs/AUTH_SETUP_CLERK.md)
CLERK_ACCOUNTS_URL=https://accounts.viger.cloud
VITE_CLERK_ACCOUNTS_URL=https://accounts.viger.cloud
# Recommended behind Nginx/reverse proxy — avoids Clerk HTTPS detection issues (see docs/AUTH_SETUP_CLERK.md)
# VITE_CLERK_PROXY_URL=https://clerk.viger.cloud

# Replit OIDC — only when AUTH_PROVIDER=replit
REPL_ID=
REPLIT_DOMAINS=

# Must be 0 or unset in production (app refuses DEV_AUTH_BYPASS=1)
DEV_AUTH_BYPASS=0
PHASE2D_TEST=0

# Optional — client error reporting (baked in at npm run build; no-op when unset)
# VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
# VITE_SENTRY_REPLAY_SESSION_RATE=0.1
# VITE_SENTRY_SEND_PII=0
# VITE_APP_VERSION=1.0.0
# Source maps upload (VPS build only — never commit token):
# SENTRY_AUTH_TOKEN=sntrys_...
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug

# Optional — product analytics (Plausible; no-op when unset) — see docs/ANALYTICS.md
# VITE_PLAUSIBLE_DOMAIN=viger.cloud

# --- Email receipts (F1 / Resend) ---
RESEND_API_KEY=
RECEIPT_FROM_EMAIL=receipts@yourdomain.com
RECEIPT_SIGNING_SECRET=CHANGE_ME_receipt_hmac_secret_32_chars_min

# Optional
DB_DRIVER=node-postgres
SESSION_COOKIE_SECURE=1
ISSUER_URL=https://replit.com/oidc

# --- Nightly backup (Neon → Cloudflare R2) — see docs/DISASTER_RECOVERY.md ---
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=midnight-backups
R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_REGION=auto
# BACKUP_RETENTION_DAYS=30
# BACKUP_NOTIFY_WEBHOOK=

# Optional — server error reporting (runtime env; no-op when unset)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_TRACES_SAMPLE_RATE=0

# --- WhatsApp Business (Cloud API) — see docs/integrations/whatsapp-business.md ---
# Disabled by default. Outbound sends and webhook processing are no-ops until enabled.
WHATSAPP_ENABLED=false
# Token you invent and also enter in the Meta webhook config (verifies GET challenge).
WHATSAPP_VERIFY_TOKEN=
# Permanent system-user access token (server-only secret — never sent to the browser).
WHATSAPP_ACCESS_TOKEN=
# Phone number ID from the WhatsApp > API Setup screen (NOT the phone number itself).
WHATSAPP_PHONE_NUMBER_ID=
# WhatsApp Business Account (WABA) ID — used for template sync.
WHATSAPP_BUSINESS_ACCOUNT_ID=
# Meta app secret — used to verify the X-Hub-Signature-256 webhook HMAC.
WHATSAPP_APP_SECRET=
# Default country dialing code for normalising local numbers (UK = 44).
WHATSAPP_DEFAULT_COUNTRY_CODE=44

# --- Docker Compose only (ignore for PM2 deploy) ---
POSTGRES_USER=midnight
POSTGRES_PASSWORD=CHANGE_ME_database_password
POSTGRES_DB=midnight_epos
APP_PORT=5000
