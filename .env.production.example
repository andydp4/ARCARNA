# Copy to .env.production on the VPS (never commit secrets)

# --- Postgres (docker-compose service) ---
POSTGRES_USER=midnight
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=midnight_epos

# --- App ---
APP_PORT=5000
NODE_ENV=production
PORT=5000
DB_DRIVER=node-postgres
DATABASE_URL=postgresql://midnight:change_me_strong_password@postgres:5432/midnight_epos
SESSION_SECRET=change_me_at_least_32_random_characters_long
# Set to 1 when TLS terminates at reverse proxy (nginx/Caddy)
SESSION_COOKIE_SECURE=0

# --- Auth (Replit OIDC) ---
REPL_ID=
ISSUER_URL=https://replit.com/oidc
REPLIT_DOMAINS=your-domain.example.com

# --- Must stay off in production ---
DEV_AUTH_BYPASS=0
PHASE2D_TEST=0
