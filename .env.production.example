# =============================================================================
# MidnightEPOS production settings (Hostinger VPS)
# =============================================================================
# ON THE SERVER:  cp .env.production.example .env.production
#                 nano .env.production
# Clerk setup: docs/AUTH_SETUP_CLERK.md
# Deploy steps: docs/DEPLOYMENT_HOSTINGER_VPS.md
# =============================================================================

# Database password (pick a long random password and save it somewhere safe)
POSTGRES_USER=midnight
POSTGRES_PASSWORD=CHANGE_ME_database_password
POSTGRES_DB=midnight_epos

# App port (leave 5000 unless Hostinger told you otherwise)
APP_PORT=5000

# Session secret (still required — 32+ random characters)
SESSION_SECRET=CHANGE_ME_session_secret_at_least_32_characters

# Auth provider: clerk (production default) | replit (legacy rollback)
AUTH_PROVIDER=clerk

# Clerk (production login) — from https://dashboard.clerk.com → API Keys
CLERK_PUBLISHABLE_KEY=pk_live_CHANGE_ME
CLERK_SECRET_KEY=sk_live_CHANGE_ME

# Replit OIDC (only if AUTH_PROVIDER=replit)
REPL_ID=
REPLIT_DOMAINS=

# Leave these alone for production
NODE_ENV=production
PORT=5000
DB_DRIVER=node-postgres
DATABASE_URL=postgresql://midnight:CHANGE_ME_database_password@postgres:5432/midnight_epos
SESSION_COOKIE_SECURE=0
ISSUER_URL=https://replit.com/oidc
DEV_AUTH_BYPASS=0
PHASE2D_TEST=0
