# =============================================================================
# MidnightEPOS production — Node/PM2/Nginx (https://viger.cloud) or Docker
# =============================================================================
# Copy:  cp .env.production.example .env
# Clerk: docs/AUTH_SETUP_CLERK.md
# PM2:  docs/DEPLOY_HOSTINGER_VPS.md
# =============================================================================

NODE_ENV=production
PORT=5000

# PostgreSQL (Neon or self-hosted) — rotate credentials if ever exposed in chat/logs
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Session signing (32+ random characters; required even with Clerk)
SESSION_SECRET=CHANGE_ME_session_secret_at_least_32_characters

# Auth: clerk (production default) | replit (legacy rollback only)
AUTH_PROVIDER=clerk
CLERK_SECRET_KEY=sk_live_CHANGE_ME
CLERK_PUBLISHABLE_KEY=pk_live_CHANGE_ME

# Baked into frontend at npm run build (must match Clerk dashboard)
VITE_AUTH_PROVIDER=clerk
VITE_CLERK_PUBLISHABLE_KEY=pk_live_CHANGE_ME
VITE_APP_URL=https://viger.cloud

# Clerk Account Portal (DNS must point accounts.* to Clerk — see docs/AUTH_SETUP_CLERK.md)
CLERK_ACCOUNTS_URL=https://accounts.viger.cloud
VITE_CLERK_ACCOUNTS_URL=https://accounts.viger.cloud

# Replit OIDC — only when AUTH_PROVIDER=replit
REPL_ID=
REPLIT_DOMAINS=

# Must be 0 or unset in production (app refuses DEV_AUTH_BYPASS=1)
DEV_AUTH_BYPASS=0
PHASE2D_TEST=0

# Optional
DB_DRIVER=node-postgres
SESSION_COOKIE_SECURE=1
ISSUER_URL=https://replit.com/oidc

# --- Docker Compose only (ignore for PM2 deploy) ---
POSTGRES_USER=midnight
POSTGRES_PASSWORD=CHANGE_ME_database_password
POSTGRES_DB=midnight_epos
APP_PORT=5000
