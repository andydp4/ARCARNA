# =============================================================================
# MidnightEPOS production settings (Hostinger VPS)
# =============================================================================
# ON THE SERVER:  cp .env.production.example .env.production
#                 nano .env.production
# Then edit the three CHANGE_ME values below. See docs/DEPLOYMENT_HOSTINGER_VPS.md
# =============================================================================

# Database password (pick a long random password and save it somewhere safe)
POSTGRES_USER=midnight
POSTGRES_PASSWORD=CHANGE_ME_database_password
POSTGRES_DB=midnight_epos

# App port (leave 5000 unless Hostinger told you otherwise)
APP_PORT=5000

# Session secret (pick 32+ random letters/numbers — like a second password)
SESSION_SECRET=CHANGE_ME_session_secret_at_least_32_characters

# Login (Replit) — ask your developer to fill these for your real domain
REPL_ID=
REPLIT_DOMAINS=

# Leave these alone for first install
NODE_ENV=production
PORT=5000
DB_DRIVER=node-postgres
# Must use the SAME password as POSTGRES_PASSWORD above:
DATABASE_URL=postgresql://midnight:CHANGE_ME_database_password@postgres:5432/midnight_epos
SESSION_COOKIE_SECURE=0
ISSUER_URL=https://replit.com/oidc
DEV_AUTH_BYPASS=0
PHASE2D_TEST=0
