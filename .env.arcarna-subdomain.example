# =============================================================================
# ARCARNA EPOS — root-mounted subdomain deploy (https://arcarna.viger.cloud)
# =============================================================================
# Runs as a second PM2 process ("arcarna-epos-sub") alongside the existing
# path-mounted process, from the SAME checkout. Copy, fill in secrets (same
# values as .env), then see docs/ops/SUBDOMAIN_MIGRATION_ARCARNA.md for the
# build + nginx + Clerk steps.
#
#   cp .env.arcarna-subdomain.example .env.arcarna-subdomain
# =============================================================================

NODE_ENV=production
PORT=5001

# Separate client build output so it doesn't collide with the /arcarna build
# in dist/public (each bakes in a different base path). Built via:
#   DIST_PUBLIC_DIR=dist/public-arcarna VITE_BASE_PATH=/ npx vite build
DIST_PUBLIC_DIR=dist/public-arcarna

# Root-mounted: no path prefix, no portal (portal only makes sense when
# something else owns "/" — see server/index.ts).
VITE_BASE_PATH=/
APP_BASE_PATH=/
VITE_APP_URL=https://arcarna.viger.cloud

# --- Everything below should match .env (same DB, same secrets, same Clerk app) ---
DATABASE_URL=
SESSION_SECRET=
AUTH_PROVIDER=clerk
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
VITE_AUTH_PROVIDER=clerk
VITE_CLERK_PUBLISHABLE_KEY=

# Clerk Account Portal stays on accounts.viger.cloud — arcarna.viger.cloud is
# a same-registrable-domain subdomain, so Clerk shares sessions automatically
# (NOT a satellite; see client/src/lib/authConfig.ts usesClerkSatelliteDomain).
CLERK_ACCOUNTS_URL=https://accounts.viger.cloud
VITE_CLERK_ACCOUNTS_URL=https://accounts.viger.cloud

DEV_AUTH_BYPASS=0
PHASE2D_TEST=0

# Optional — keep in sync with .env if used
# VITE_SENTRY_DSN=
# VITE_PLAUSIBLE_DOMAIN=arcarna.viger.cloud
RESEND_API_KEY=
RECEIPT_FROM_EMAIL=
RECEIPT_SIGNING_SECRET=
WHATSAPP_ENABLED=false
